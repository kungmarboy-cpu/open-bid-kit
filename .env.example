# Open Bid Kit Pro - 环境配置
# 复制此文件为 .env 并按需修改

# ========== AI 模型配置 ==========
# 推荐：DeepSeek / OpenAI / 火山引擎 / 硅基流动 / Ollama
AI_PROVIDER=deepseek
AI_API_KEY=your-api-key-here
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# 使用 OpenAI 兼容接口时配置
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# 使用 Ollama 本地模型时配置
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3

# ========== Notion 集成配置 ==========
NOTION_API_KEY=your-notion-api-key-here
NOTION_KNOWLEDGEBASE_DATABASE_ID=your-database-id-here

# ========== 知识库配置 ==========
KNOWLEDGE_BASE_PATH=./knowledge-base
VECTOR_STORE_PATH=./vector-store

# ========== 商机监控配置 ==========
# 抓取招投标公告的API端点
BID_OPPORTUNITY_ENABLED=false
BID_OPPORTUNITY_API_URL=
BID_OPPORTUNITY_KEYWORDS=IT,信息化,系统集成

# ========== 文档排版配置 ==========
OUTPUT_DIR=./output
DEFAULT_TEMPLATE=standard

# ========== OCR配置 ==========
# MinerU OCR 服务配置
MINERU_ENABLED=false
MINERU_API_KEY=
MINERU_ENDPOINT=
